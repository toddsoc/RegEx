limit_req_zone $binary_remote_addr zone=regex_search:10m rate=30r/m;

server {
    listen 80;
    listen [::]:80;
    server_name your-domain.example;
    absolute_redirect off;
    client_max_body_size 4k;
    limit_req_status 429;

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "same-origin" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'" always;

    location = / {
        return 302 /RegEx/;
    }

    location = /RegEx {
        return 302 /RegEx/;
    }

    location /RegEx/static/ {
        alias /var/www/word-regex-search/apps/regex/src/word_regex_app/static/;
        expires 1d;
        add_header Cache-Control "public";
    }

    location /RegEx/ {
        limit_req zone=regex_search burst=10 nodelay;
        include proxy_params;
        proxy_pass http://unix:/run/word-regex-search.sock:/;
        proxy_set_header X-Forwarded-Prefix /RegEx;
        proxy_read_timeout 30s;
    }
}
